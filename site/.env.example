# Limitless spectator markets. Keep mock mode and trading disabled until
# Limitless approves the project and issues server-only partner credentials.
LIMITLESS_MODE=mock
LIMITLESS_TRADING_ENABLED=false
LIMITLESS_API_BASE_URL=https://api.limitless.exchange
LIMITLESS_API_TOKEN_ID=
LIMITLESS_API_SECRET=
# Key: canonical match key. yesTokenId identifies the athlete represented by YES.
LIMITLESS_MATCH_MARKETS_JSON={"gravity-goons:skateboarding:34-35":{"slug":"approved-limitless-market-slug","yesTokenId":34}}
